# ---------- Modes ----------
BRD_ANALYZER_MODE=hybrid
BA_AGENT_MODE=hybrid
SA_AGENT_MODE=hybrid
DEV_AGENT_MODE=hybrid
QA_AGENT_MODE=hybrid

# ---------- Optional Foundry/Anthropic Defaults ----------
# If set, these can be used as implicit fallbacks by config.py.
ANTHROPIC_FOUNDRY_BASE_URL=
ANTHROPIC_FOUNDRY_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-3-5-sonnet-20241022

# ---------- Model (LiteLLM format) ----------
# Change to another Sonnet model if your account does not support this one.
BRD_LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
BA_LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
SA_LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
DEV_LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
QA_LLM_MODEL=anthropic/claude-3-5-sonnet-20241022

# ---------- API Keys ----------
# Replace with your real Anthropic key
BRD_LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
BA_LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
SA_LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
DEV_LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
QA_LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Optional fallback key (unused for Anthropic route)
OPENAI_API_KEY=

# ---------- Base URL ----------
BRD_LLM_BASE_URL=
BA_LLM_BASE_URL=
SA_LLM_BASE_URL=
DEV_LLM_BASE_URL=
QA_LLM_BASE_URL=

# ---------- Temperatures ----------
BRD_LLM_TEMPERATURE=0.0
BA_LLM_TEMPERATURE=0.2
SA_LLM_TEMPERATURE=0.2
DEV_LLM_TEMPERATURE=0.2
QA_LLM_TEMPERATURE=0.2

# ---------- Prompts ----------
BRD_EXTRACTION_PROMPT_PATH=prompts/brd_extraction_prompt.md
BA_TASK_PROMPT_PATH=prompts/ba_task_prompt.md
BA_REVIEW_PROMPT_PATH=prompts/ba_review_prompt.md
SA_ARCH_PROMPT_PATH=prompts/sa_architecture_prompt.md
SA_DEV_PLAN_PROMPT_PATH=prompts/sa_dev_plan_prompt.md
SA_ARCH_REVIEW_PROMPT_PATH=prompts/sa_architecture_review_prompt.md
SA_DEV_PLAN_REVIEW_PROMPT_PATH=prompts/sa_dev_plan_review_prompt.md
DEV_CODE_PROMPT_PATH=prompts/dev_code_prompt.md
DEV_REVIEW_PROMPT_PATH=prompts/dev_review_prompt.md
QA_PLAN_PROMPT_PATH=prompts/qa_test_plan_prompt.md
QA_REVIEW_PROMPT_PATH=prompts/qa_review_prompt.md

# ---------- Review loops ----------
BA_REVIEW_ITERATIONS=1
SA_REVIEW_ITERATIONS=1
DEV_REVIEW_ITERATIONS=1
QA_REVIEW_ITERATIONS=1
